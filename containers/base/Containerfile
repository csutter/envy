FROM quay.io/fedora/fedora:44

# Ensure reasonable default locale
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Ensure dnf installs docs
RUN sed -i '/tsflags=nodocs/d' /etc/dnf/dnf.conf || true

# Update and install packages
RUN dnf copr enable -y jdxcode/mise && \
    dnf -y upgrade && \
    dnf -y swap coreutils-single coreutils-full && \
    dnf -y swap glibc-minimal-langpack glibc-langpack-en && \
    dnf -y install \
        bash-completion \
        ca-certificates \
        curl \
        diffutils \
        fd-find \
        findutils \
        fish \
        git \
        gzip \
        hostname \
        info \
        iproute \
        iputils \
        less \
        man-db \
        man-pages \
        mise \
        ncurses \
        pinfo \
        procps-ng \
        ripgrep \
        shadow-utils \
        sudo \
        tar \
        tree \
        unzip \
        util-linux \
        vim-minimal \
        which \
        xz \
        zip && \
    dnf clean all

# User setup
ARG USERNAME=dev
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd --gid ${USER_GID} ${USERNAME} \
  && useradd --uid ${USER_UID} --gid ${USER_GID} -m ${USERNAME} -s /usr/bin/fish \
  && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} \
  && chmod 0440 /etc/sudoers.d/${USERNAME}

# Set up workspace directory
RUN mkdir -p /workspace && chown ${USERNAME}:${USERNAME} /workspace

# Switch to user and set working directory
USER ${USERNAME}
WORKDIR /workspace

# Set up sensible environment defaults
ENV COLORTERM=truecolor
ENV DEVCONTAINER=true
ENV SHELL=/usr/bin/fish
ENV TERM=xterm-256color

# Ensure shell is set as default if not already set
SHELL ["/usr/bin/fish", "-c"]
CMD ["/usr/bin/fish"]
